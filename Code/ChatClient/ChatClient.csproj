
using System;
using System.Drawing;
using System.Net.Sockets;
using System.Text;
using System.Windows.Forms;

namespace MyClientApp;

public partial class Form1 : Form
{
    private TextBox txtNickname, txtChatBox, txtInput;
    private Button btnConnect, btnSend;
    private TcpClient? client;
    private NetworkStream? stream;

    public Form1()
    {
        InitializeCustomComponents();
    }

    private void InitializeCustomComponents()
    {
        this.Text = "Chat Client - Member 4";
        this.Size = new Size(500, 600);
        this.StartPosition = FormStartPosition.CenterScreen;

        // 1. Ô nhập Nickname (Dòng 1)
        txtNickname = new TextBox { Location = new Point(20, 20), Width = 200, PlaceholderText = "Nhập Nickname..." };
        
        // 2. Nút Kết nối (Dòng 1 - Cạnh ô tên)
        btnConnect = new Button { Location = new Point(230, 18), Text = "Kết nối Server", Width = 120, Height = 30, BackColor = Color.LightBlue };
        btnConnect.Click += BtnConnect_Click;

        // 3. Khung hiển thị Chat (Ở giữa)
        txtChatBox = new TextBox { 
            Location = new Point(20, 60), 
            Size = new Size(440, 350), 
            Multiline = true, 
            ReadOnly = true, 
            ScrollBars = ScrollBars.Vertical 
        };

        // 4. Ô nhập tin nhắn (Dưới cùng)
        txtInput = new TextBox { 
            Location = new Point(20, 430), 
            Size = new Size(340, 80), 
            Multiline = true,
            PlaceholderText = "Nhập tin nhắn tại đây..."
        };

        // 5. Nút Gửi (Cạnh ô nhập tin nhắn)
        btnSend = new Button { 
            Location = new Point(370, 430), 
            Size = new Size(90, 80), 
            Text = "Gửi", 
            Enabled = false,
            BackColor = Color.LightGreen 
        };
        btnSend.Click += BtnSend_Click;

        this.Controls.AddRange(new Control[] { txtNickname, btnConnect, txtChatBox, txtInput, btnSend });
    }

    private void BtnConnect_Click(object? sender, EventArgs e)
    {
        if (string.IsNullOrWhiteSpace(txtNickname.Text)) {
            MessageBox.Show("Vui lòng nhập tên!"); return;
        }

        try {
            client = new TcpClient("127.0.0.1", 8888); // Kết nối thử tới máy cá nhân
            stream = client.GetStream();
            
            // Gửi gói tin đăng nhập theo quy định tạm thời
            string loginMsg = $"LOGIN|{txtNickname.Text}|SERVER|Hello";
            byte[] data = Encoding.UTF8.GetBytes(loginMsg);
            stream.Write(data, 0, data.Length);

            txtChatBox.AppendText("Hệ thống: Đã kết nối! Đang chờ Server phản hồi..." + Environment.NewLine);
            btnConnect.Enabled = false;
            btnSend.Enabled = true;
        }
        catch (Exception) {
            MessageBox.Show("Chưa tìm thấy Server (Thành viên 2 chưa bật Server). Nhưng code của bạn đã chạy đúng!");
        }
    }

    private void BtnSend_Click(object? sender, EventArgs e)
    {
        if (stream != null && !string.IsNullOrWhiteSpace(txtInput.Text)) {
            string msg = $"CHAT|{txtNickname.Text}|ALL|{txtInput.Text}";
            byte[] data = Encoding.UTF8.GetBytes(msg);
            stream.Write(data, 0, data.Length);
            txtChatBox.AppendText($"[Tôi]: {txtInput.Text}" + Environment.NewLine);
            txtInput.Clear();
        }
    }
}
